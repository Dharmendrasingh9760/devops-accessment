# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git (it is in .gitignore).

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_to_a_strong_random_password
POSTGRES_DB=appdb

# --- Redis ---
REDIS_PASSWORD=change_me_to_a_strong_random_password

# --- App ---
LOG_LEVEL=INFO

# --- Domain (used by NGINX/SSL setup, optional) ---
DOMAIN_NAME=example.com
